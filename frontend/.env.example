# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat
EXPO_PUBLIC_RC_IOS_PRODUCTION_KEY=
EXPO_PUBLIC_RC_ANDROID_PRODUCTION_KEY=
EXPO_PUBLIC_RC_TEST_KEY=

# Backend
EXPO_PUBLIC_BACKEND_URL=https://fishing-lure-backend.onrender.com

# Auth
# Auth email links — must also be allowlisted in Supabase → Authentication → URL Configuration → Redirect URLs
EXPO_PUBLIC_PASSWORD_RESET_URL=https://sameasabove.github.io/fishing-lure-classifier/backend/password-reset-success.html
EXPO_PUBLIC_EMAIL_CONFIRM_REDIRECT_URL=https://sameasabove.github.io/fishing-lure-classifier/backend/confirm-email-success.html

# Legal (subscription paywall — App Store Guideline 3.1.2; omit to use same defaults as config/index.js)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://sameasabove.github.io/fishing-lure-classifier/backend/PRIVACY_POLICY.html
